# Zer0Fit configuration — copy to .env and adjust as needed.
# This file is automatically generated by install.sh on first run.

# Target architecture: amd64 (x86_64) or arm64 (ARM64/Blackwell)
# install.sh auto-detects this — only change manually if cross-building.
BUILDARCH=amd64

# Base Docker image
# NVIDIA x86_64:  nvidia/cuda:12.4.1-base-ubuntu24.04
# NVIDIA ARM64:   nvidia/cuda:13.2.0-base-ubuntu24.04
# AMD ROCm:       ubuntu:24.04  (the ROCm torch wheels bundle the HIP userspace)
BASE_IMAGE=nvidia/cuda:12.4.1-base-ubuntu24.04

# PyTorch wheel index URL
# NVIDIA x86_64:  https://download.pytorch.org/whl/cu124
# NVIDIA ARM64:   https://download.pytorch.org/whl/nightly/cu130
# AMD ROCm:       https://download.pytorch.org/whl/rocm7.2
TORCH_INDEX=https://download.pytorch.org/whl/cu124

# ── AMD ROCm settings (gpu-rocm compose profile only) ──────────────────────
# Host GIDs owning /dev/dri/renderD* (render) and /dev/dri/card* (video).
# install.sh detects these from the host with `getent group`.
#VIDEO_GID=44
#RENDER_GID=992

# gfx override for GPUs missing from the ROCm kernel bundle — e.g. gfx1103
# RDNA3 APUs need "11.0.0". Leave unset for natively supported GPUs
# (an empty value is treated as unset by the server).
#HSA_OVERRIDE_GFX_VERSION=11.0.0

# Select a specific GPU on multi-GPU hosts (e.g. 0). Unset = all GPUs.
#HIP_VISIBLE_DEVICES=0

# Hugging Face model cache location. Default: the "hf-cache" named Docker
# volume (weights persist across container recreation / image rebuilds).
# Set to an absolute host path to reuse an existing HF cache and avoid
# re-downloading model weights (must be writable by the container user).
#ZER0FIT_HF_CACHE=/home/youruser/.cache/huggingface

# Idle VRAM TTL — seconds before auto-unloading model from GPU (default 300)
ZER0FIT_VRAM_TTL=300

# Port to expose the MCP server on (default 8002)
ZER0FIT_PORT=8002

# Upload TTL — hours before auto-deleting chat-attached CSV files (default 6)
ZER0FIT_UPLOAD_TTL_HOURS=6

# Log level — DEBUG, INFO, WARNING, ERROR (default INFO)
ZER0FIT_LOG_LEVEL=INFO

# Upload directory — where inline file_data and uploaded files are stored
# (default /app/uploads — inside the container, not on a host-mounted volume)
ZER0FIT_UPLOAD_DIR=/app/uploads

# Open WebUI uploads directory — where OWUI stores chat-attached files
# (default /app/webui_data/uploads)
ZER0FIT_WEBUI_DIR=/app/webui_data/uploads

# Max upload size in MB (default 50)
ZER0FIT_MAX_UPLOAD_MB=50

# Enable Starlette debug mode — leaks tracebacks to HTTP clients (default false)
# Only enable for local development, never in production.
ZER0FIT_DEBUG=false

# TabFM git ref (branch, tag, or SHA) to clone during build.
# Pinned to a specific SHA for reproducible builds — update manually
# after verifying compatibility with a new TabFM release.
TABFM_REF=d8678b6895f1428a468d4cc299c1ff4cf704e726